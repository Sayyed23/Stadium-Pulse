{
  "name": "stadium-pulse-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "StadiumPulse AI - GenAI Stadium Operations & Fan Experience Platform",
  "scripts": {
    "dev": "pnpm --filter \"*\" --parallel dev",
    "build": "pnpm --filter \"*\" build",
    "start": "pnpm --filter \"*\" start",
    "lint": "pnpm --filter \"*\" lint",
    "test": "pnpm --filter \"*\" test",
    "db:generate": "pnpm --filter @stadiumpulse/db generate",
    "db:push": "pnpm --filter @stadiumpulse/db push",
    "db:seed": "pnpm --filter @stadiumpulse/db seed"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.12.7"
  }
}
